# Supabase configuration
# If a real .env was previously committed for a production or semi-production
# project, rotate exposed Supabase keys from the Supabase dashboard.
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Crypto billing configuration
VITE_DAAR_PURCHASE_URL=https://app.daarion.city/

# Polygon-only MVP payment network.
VITE_DAARION_PAYMENT_NETWORK=polygon

# DAARION DAO multisig treasury receiving wallet on Polygon.
# Public receiving address only. Never add private keys or seed phrases.
VITE_DAARION_TREASURY_EVM_ADDRESS=0x0000000000000000000000000000000000000000

# Optional future token contract address.
# This is NOT a receiving wallet.
VITE_DAAR_TOKEN_CONTRACT_POLYGON=
